APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# 翻訳API（ルーム名・リプライ本文のGPT-4o mini翻訳用）
OPENAI_API_KEY=
# 翻訳API専用タイムアウト（秒）。transport_timeout が出る場合は 15 → 20 → 25 で段階調整
OPENAI_TRANSLATION_TIMEOUT_SECONDS=15
# テスト用: 外部API（翻訳・Safe Browsing・Veriphone・Cloudflare等）呼び出し時にブラウザで「どのAPIが呼ばれたか」をアラート表示（true で有効）
# EXTERNAL_API_DEBUG_ALERT=true

# 電話番号検証（Veriphone）。未設定時は local/testing または下記を true にすると検証スキップ
# VERIPHONE_API_KEY=
# 本番で検証を一時的に止めたい場合は false（APIを呼ばず全番号を許可）
# VERIPHONE_ENABLED=true
# テスト時のみ: API未設定でも電話番号を通す（本番では true にしないこと）
# VERIPHONE_SKIP_WHEN_NO_KEY=true
# 開発環境でAPIをスキップするか。false にすると local でも Veriphone を呼び出す（APIキー必須）
# VERIPHONE_SKIP_IN_DEV=false

# テスト用: SMS/メール認証画面で認証コードを表示（本番では true にしないこと）
# SHOW_VERIFICATION_CODE_ON_SCREEN=true

# 管理者画面のURLパス（必ず設定すること。未設定だと起動時のランダム値になりURLが分からない）
# 例: ADMIN_PREFIX=manage → https://あなたのドメイン/manage
# 変更後は php artisan config:clear を実行すること
# ADMIN_PREFIX=your-secret-admin-path

# ファイルアップロード・メディア検証
# ClamAV ウイルススキャン: 有効にする場合は true（要: ClamAV インストール）。未設定・false のときはスキャンしない
# CLAMAV_ENABLED=true
# 開発用: ffprobe/ClamAV が未導入でも検証をスキップしてアップロードを通す（本番では false 推奨）
# SKIP_MEDIA_VALIDATION_TOOLS=false

# Safe Browsing API（URL 安全性チェック）
# 有効時は Google Safe Browsing API で投稿内 URL をチェック。false にするとチェックをスキップ
# SAFEBROWSING_ENABLED=true
# SAFEBROWSING_API_KEY=  # 有効時は必須（Google Cloud で API キーを発行）
